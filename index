<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Urban Línea — Muebles de Madera Honduras</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── TOKENS ───────────────────────────────────────────── */
    :root {
      --cream:    #F5F0E8;
      --sand:     #EDD9B4;
      --caramel:  #B07D50;
      --brown:    #7B3410;
      --slate:    #8A8085;
      --charcoal: #3A3535;
      --white:    #FFFFFF;

      --ff-display: 'Times New Roman', Georgia, serif; /* The Youngest Serif fallback */
      --ff-body:    'Poppins', sans-serif;

      --radius: 4px;
      --transition: 0.35s cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--ff-body);
      background: var(--cream);
      color: var(--charcoal);
      font-size: 15px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; width: 100%; object-fit: cover; }
    a   { text-decoration: none; color: inherit; }

    /* ── NAV ──────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 6%;
      background: rgba(245,240,232,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(176,125,80,0.15);
      transition: box-shadow var(--transition);
    }
    nav.scrolled { box-shadow: 0 2px 20px rgba(58,53,53,0.08); }

    .nav-logo {
      font-family: var(--ff-display);
      font-size: 1.5rem;
      letter-spacing: 0.18em;
      color: var(--brown);
      text-transform: uppercase;
    }
    .nav-logo span { color: var(--caramel); }

    .nav-links { display: flex; gap: 36px; }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--charcoal);
      position: relative;
      transition: color var(--transition);
    }
    .nav-links a::after {
      content: '';
      position: absolute; bottom: -4px; left: 0; right: 0; height: 1px;
      background: var(--brown);
      transform: scaleX(0); transform-origin: left;
      transition: transform var(--transition);
    }
    .nav-links a:hover { color: var(--brown); }
    .nav-links a:hover::after { transform: scaleX(1); }

    .nav-cta {
      background: var(--brown);
      color: var(--cream) !important;
      padding: 9px 22px;
      border-radius: var(--radius);
      font-size: 0.75rem !important;
      letter-spacing: 0.1em !important;
      transition: background var(--transition), transform var(--transition) !important;
    }
    .nav-cta::after { display: none !important; }
    .nav-cta:hover { background: var(--caramel) !important; transform: translateY(-1px); }

    /* ── HERO ─────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 74px;
    }

    .hero-text {
      display: flex; flex-direction: column; justify-content: center;
      padding: 80px 6% 80px 8%;
      background: var(--cream);
    }

    .hero-eyebrow {
      font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--caramel); margin-bottom: 20px;
    }

    .hero-title {
      font-family: var(--ff-display);
      font-size: clamp(2.8rem, 4.5vw, 4.8rem);
      line-height: 1.08;
      color: var(--brown);
      margin-bottom: 24px;
    }
    .hero-title em { font-style: italic; color: var(--caramel); }

    .hero-sub {
      font-size: 0.95rem; font-weight: 300;
      color: var(--slate); max-width: 420px;
      margin-bottom: 44px; line-height: 1.8;
    }

    .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--brown); color: var(--cream);
      padding: 14px 30px; border-radius: var(--radius);
      font-size: 0.82rem; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: background var(--transition), transform var(--transition);
    }
    .btn-primary:hover { background: var(--caramel); transform: translateY(-2px); }

    .btn-outline {
      display: inline-flex; align-items: center; gap: 10px;
      border: 1.5px solid var(--brown); color: var(--brown);
      padding: 14px 30px; border-radius: var(--radius);
      font-size: 0.82rem; font-weight: 500; letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: background var(--transition), color var(--transition), transform var(--transition);
    }
    .btn-outline:hover { background: var(--brown); color: var(--cream); transform: translateY(-2px); }

    .hero-image {
      position: relative; overflow: hidden;
      background: var(--charcoal);
    }
    .hero-image img {
      height: 100%; object-position: center;
      transition: transform 8s ease;
    }
    .hero-image:hover img { transform: scale(1.04); }

    .hero-badge {
      position: absolute; bottom: 40px; left: -20px;
      background: var(--brown); color: var(--cream);
      padding: 18px 28px 18px 40px;
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    .hero-badge strong {
      font-family: var(--ff-display);
      font-size: 2.2rem; display: block; line-height: 1;
    }
    .hero-badge span { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.8; }

    /* ── SECTION SHELL ────────────────────────────────────── */
    section { padding: 96px 8%; }

    .section-label {
      font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--caramel); margin-bottom: 12px;
    }

    .section-title {
      font-family: var(--ff-display);
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--brown); line-height: 1.15;
      margin-bottom: 16px;
    }

    .section-sub {
      font-size: 0.92rem; font-weight: 300;
      color: var(--slate); max-width: 520px; line-height: 1.9;
    }

    /* ── STATS BAR ────────────────────────────────────────── */
    .stats {
      background: var(--brown);
      padding: 52px 8%;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 32px; text-align: center;
    }
    .stat-num {
      font-family: var(--ff-display);
      font-size: 3rem; color: var(--sand); line-height: 1;
      margin-bottom: 8px;
    }
    .stat-label {
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(237,217,180,0.65);
    }

    /* ── PORTAFOLIO ───────────────────────────────────────── */
    .portfolio { background: var(--white); }

    .portfolio-header {
      display: flex; align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 56px; flex-wrap: wrap; gap: 20px;
    }

    .tabs {
      display: flex; gap: 4px;
      background: var(--cream); padding: 4px;
      border-radius: var(--radius);
    }
    .tab {
      padding: 8px 20px; border-radius: var(--radius);
      font-size: 0.75rem; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: background var(--transition), color var(--transition);
      color: var(--slate); border: none; background: transparent;
    }
    .tab.active, .tab:hover { background: var(--brown); color: var(--cream); }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .product-card {
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--cream);
      transition: transform var(--transition), box-shadow var(--transition);
      cursor: pointer;
    }
    .product-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 48px rgba(123,52,16,0.12);
    }
    .product-card:first-child {
      grid-column: span 2; grid-row: span 2;
    }

    .card-img-wrap { position: relative; overflow: hidden; }
    .product-card:first-child .card-img-wrap { height: 460px; }
    .card-img-wrap { height: 200px; }

    .card-img-wrap img { transition: transform var(--transition); height: 100%; }
    .product-card:hover .card-img-wrap img { transform: scale(1.06); }

    .card-tag {
      position: absolute; top: 14px; left: 14px;
      background: var(--brown); color: var(--cream);
      font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 2px;
    }

    .card-body { padding: 20px 22px 24px; }
    .card-cat {
      font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--caramel); margin-bottom: 6px;
    }
    .card-name {
      font-family: var(--ff-display);
      font-size: 1.15rem; color: var(--brown); margin-bottom: 8px;
    }
    .card-desc {
      font-size: 0.8rem; color: var(--slate); line-height: 1.7;
      margin-bottom: 16px;
    }
    .card-link {
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--brown);
      display: inline-flex; align-items: center; gap: 8px;
      transition: gap var(--transition), color var(--transition);
    }
    .card-link:hover { gap: 14px; color: var(--caramel); }

    /* ── NOSOTROS ─────────────────────────────────────────── */
    .about {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: center;
      background: var(--cream);
    }

    .about-images {
      display: grid; grid-template-columns: 1fr 1fr;
      grid-template-rows: 260px 260px;
      gap: 12px;
    }
    .about-images .img-tall {
      grid-row: span 2; border-radius: var(--radius);
      overflow: hidden;
    }
    .about-images .img-short {
      border-radius: var(--radius); overflow: hidden;
    }
    .about-images img { height: 100%; }

    .about-values { margin-top: 40px; display: flex; flex-direction: column; gap: 16px; }
    .value-row {
      display: flex; align-items: center; gap: 16px;
      padding: 14px 18px;
      border-left: 3px solid var(--sand);
      background: var(--white);
      border-radius: 0 var(--radius) var(--radius) 0;
      transition: border-color var(--transition);
    }
    .value-row:hover { border-color: var(--brown); }
    .value-icon { font-size: 1.3rem; }
    .value-name {
      font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--brown); margin-bottom: 2px;
    }
    .value-desc { font-size: 0.76rem; color: var(--slate); line-height: 1.6; }

    /* ── PROCESO ──────────────────────────────────────────── */
    .process { background: var(--charcoal); }
    .process .section-title { color: var(--sand); }
    .process .section-sub  { color: rgba(237,217,180,0.6); }
    .process .section-label { color: var(--caramel); }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px; margin-top: 64px;
    }
    .process-step {
      text-align: center; padding: 36px 20px;
      border: 1px solid rgba(176,125,80,0.2);
      border-radius: var(--radius);
      transition: border-color var(--transition), background var(--transition);
    }
    .process-step:hover {
      border-color: var(--caramel);
      background: rgba(176,125,80,0.06);
    }
    .step-num {
      font-family: var(--ff-display);
      font-size: 3rem; color: rgba(176,125,80,0.3);
      line-height: 1; margin-bottom: 20px;
    }
    .step-title {
      font-size: 0.85rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--sand); margin-bottom: 12px;
    }
    .step-desc { font-size: 0.78rem; color: rgba(237,217,180,0.55); line-height: 1.8; }

    /* ── TESTIMONIOS ──────────────────────────────────────── */
    .testimonials { background: var(--sand); }
    .testimonials .section-title { color: var(--brown); }

    .testi-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 24px; margin-top: 52px;
    }
    .testi-card {
      background: var(--white);
      padding: 32px 28px;
      border-radius: var(--radius);
      position: relative;
    }
    .testi-quote {
      font-family: var(--ff-display);
      font-size: 3.5rem; color: var(--sand);
      line-height: 0.8; margin-bottom: 16px;
    }
    .testi-text {
      font-size: 0.88rem; color: var(--charcoal);
      line-height: 1.85; margin-bottom: 24px; font-style: italic;
    }
    .testi-author { display: flex; align-items: center; gap: 14px; }
    .author-avatar {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--caramel);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--ff-display); font-size: 1.1rem; color: var(--cream);
      flex-shrink: 0;
    }
    .author-name {
      font-size: 0.82rem; font-weight: 600; color: var(--brown); margin-bottom: 2px;
    }
    .author-loc { font-size: 0.72rem; color: var(--slate); }
    .stars { color: var(--caramel); font-size: 0.8rem; margin-bottom: 12px; }

    /* ── CONTACTO ─────────────────────────────────────────── */
    .contact {
      background: var(--white);
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: start;
    }

    .contact-form { display: flex; flex-direction: column; gap: 16px; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label {
      font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase; color: var(--caramel);
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      font-family: var(--ff-body);
      font-size: 0.88rem; color: var(--charcoal);
      background: var(--cream);
      border: 1.5px solid transparent;
      border-radius: var(--radius);
      padding: 13px 16px;
      outline: none;
      transition: border-color var(--transition);
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: var(--brown); }
    .form-group textarea { resize: vertical; min-height: 120px; }

    .contact-info { padding-top: 8px; }
    .contact-info .section-sub { margin-bottom: 40px; }

    .contact-channels { display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; }
    .channel {
      display: flex; align-items: center; gap: 18px;
      padding: 16px 20px;
      border: 1px solid rgba(176,125,80,0.2);
      border-radius: var(--radius);
      transition: border-color var(--transition), background var(--transition);
      cursor: pointer;
    }
    .channel:hover { border-color: var(--brown); background: var(--cream); }
    .channel-icon {
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--brown); color: var(--cream);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; flex-shrink: 0;
    }
    .channel-label {
      font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--caramel); margin-bottom: 3px;
    }
    .channel-value { font-size: 0.88rem; color: var(--charcoal); font-weight: 500; }

    .map-placeholder {
      height: 180px;
      background: var(--cream);
      border-radius: var(--radius);
      display: flex; align-items: center; justify-content: center;
      border: 1px solid rgba(176,125,80,0.2);
      font-size: 0.8rem; color: var(--slate);
      letter-spacing: 0.08em; text-transform: uppercase;
    }

    /* ── WHATSAPP FLOAT ───────────────────────────────────── */
    .wa-float {
      position: fixed; bottom: 28px; right: 28px; z-index: 200;
      width: 58px; height: 58px; border-radius: 50%;
      background: #25D366;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 8px 24px rgba(37,211,102,0.35);
      cursor: pointer;
      transition: transform var(--transition), box-shadow var(--transition);
      animation: pulse-wa 3s infinite;
    }
    .wa-float:hover { transform: scale(1.12); box-shadow: 0 12px 32px rgba(37,211,102,0.5); }
    .wa-float svg { width: 30px; height: 30px; fill: white; }

    @keyframes pulse-wa {
      0%, 100% { box-shadow: 0 8px 24px rgba(37,211,102,0.35); }
      50%       { box-shadow: 0 8px 40px rgba(37,211,102,0.6); }
    }

    /* ── FOOTER ───────────────────────────────────────────── */
    footer {
      background: var(--charcoal);
      padding: 64px 8% 32px;
    }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 48px; margin-bottom: 48px;
    }
    .footer-brand .nav-logo { margin-bottom: 16px; display: block; }
    .footer-brand p { font-size: 0.8rem; color: rgba(237,217,180,0.5); line-height: 1.9; max-width: 260px; }

    .footer-col h4 {
      font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--caramel); margin-bottom: 20px;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-col li { font-size: 0.8rem; color: rgba(237,217,180,0.5); cursor: pointer; transition: color var(--transition); }
    .footer-col li:hover { color: var(--sand); }

    .footer-bottom {
      border-top: 1px solid rgba(176,125,80,0.15);
      padding-top: 28px;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 12px;
    }
    .footer-bottom p { font-size: 0.72rem; color: rgba(237,217,180,0.35); }

    .socials { display: flex; gap: 14px; }
    .social-icon {
      width: 36px; height: 36px; border-radius: 50%;
      border: 1px solid rgba(176,125,80,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem; color: rgba(237,217,180,0.5);
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition), background var(--transition);
    }
    .social-icon:hover { border-color: var(--brown); color: var(--sand); background: rgba(123,52,16,0.3); }

    /* ── SCROLL REVEAL ────────────────────────────────────── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ───────────────────────────────────────── */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .hero-image { height: 340px; }
      .stats { grid-template-columns: repeat(2,1fr); }
      .portfolio-grid { grid-template-columns: 1fr 1fr; }
      .product-card:first-child { grid-column: span 2; }
      .about { grid-template-columns: 1fr; gap: 48px; }
      .process-grid { grid-template-columns: 1fr 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .contact { grid-template-columns: 1fr; gap: 48px; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .nav-links { display: none; }
    }

    @media (max-width: 560px) {
      section { padding: 64px 5%; }
      .portfolio-grid { grid-template-columns: 1fr; }
      .product-card:first-child { grid-column: span 1; }
      .process-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .stats { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

<!-- ── NAV ── -->
<nav id="navbar">
  <span class="nav-logo">Urban<span>Línea</span></span>
  <div class="nav-links">
    <a href="#portafolio">Portafolio</a>
    <a href="#nosotros">Nosotros</a>
    <a href="#proceso">Proceso</a>
    <a href="#contacto">Contacto</a>
    <a href="#contacto" class="nav-cta">Cotizar ahora</a>
  </div>
</nav>

<!-- ── HERO ── -->
<section class="hero" id="inicio">
  <div class="hero-text">
    <p class="hero-eyebrow">Choloma, Cortés · Honduras · Desde 2000</p>
    <h1 class="hero-title">
      Muebles que <em>duran</em><br>toda la vida
    </h1>
    <p class="hero-sub">
      Fabricamos y diseñamos muebles en madera y PVC 100% a la medida.
      Más de 25 años transformando hogares hondureños con calidad artesanal.
    </p>
    <div class="hero-actions">
      <a href="#portafolio" class="btn-primary">Ver portafolio &rarr;</a>
      <a href="#contacto" class="btn-outline">Solicitar cotización</a>
    </div>
  </div>
  <div class="hero-image">
    <img
      src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=900&q=80"
      alt="Sala amueblada con madera natural"
    />
    <div class="hero-badge">
      <strong>+25</strong>
      <span>años de experiencia</span>
    </div>
  </div>
</section>

<!-- ── STATS ── -->
<div class="stats">
  <div class="reveal">
    <div class="stat-num">+500</div>
    <div class="stat-label">Clientes satisfechos</div>
  </div>
  <div class="reveal">
    <div class="stat-num">4</div>
    <div class="stat-label">Líneas de producto</div>
  </div>
  <div class="reveal">
    <div class="stat-num">100%</div>
    <div class="stat-label">Madera natural</div>
  </div>
  <div class="reveal">
    <div class="stat-num">25+</div>
    <div class="stat-label">Años en el mercado</div>
  </div>
</div>

<!-- ── PORTAFOLIO ── -->
<section class="portfolio" id="portafolio">
  <div class="portfolio-header reveal">
    <div>
      <p class="section-label">Nuestros productos</p>
      <h2 class="section-title">Todo hecho a la medida<br>de tu espacio</h2>
    </div>
